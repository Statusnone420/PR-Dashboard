{
  "name": "pr-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "test": "node --test test/*.test.js",
    "test:layout": "node node_modules/@playwright/test/cli.js test test/board-layout-a1.spec.cjs --config test/playwright-layout.config.cjs --browser=chromium --reporter=line",
    "test:readme-screenshots": "node node_modules/@playwright/test/cli.js test test/readme-gallery.spec.cjs --config test/playwright-readme.config.cjs --browser=chromium --reporter=line",
    "preview": "node node_modules/vite/bin/vite.js preview"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.0"
  }
}
